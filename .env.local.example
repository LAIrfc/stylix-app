# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development, live keys (sk_live_...) in production.
# NEVER commit real keys to version control.

STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ── Stripe Webhook ─────────────────────────────────────────────────────────────
# Set up at https://dashboard.stripe.com/webhooks
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── PayPal (Phase 2) ───────────────────────────────────────────────────────────
# Get from https://developer.paypal.com/dashboard/
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────────────────
# Create a project at https://supabase.com, then run supabase/schema.sql in the SQL editor.
# Find these values at: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin Dashboard ────────────────────────────────────────────────────────────
# Required for admin API access. Generate a strong random string (e.g. `openssl rand -base64 32`).
# Admin routes will return 503 if this is not set.
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET

# ── Meshy Image-to-3D ─────────────────────────────────────────────────────────
# Server-side only. Used by /api/3d/generate to submit product images, poll
# generation status, download the final GLB, and save it into public/models/.
MESHY_API_KEY=your-meshy-api-key-here
