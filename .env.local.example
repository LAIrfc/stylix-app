# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) during development, live keys (sk_live_...) in production.
# NEVER commit real keys to version control.

STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ── Stripe Webhook ─────────────────────────────────────────────────────────────
# Set up at https://dashboard.stripe.com/webhooks
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` locally
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# ── PayPal (Phase 2) ───────────────────────────────────────────────────────────
# Get from https://developer.paypal.com/dashboard/
NEXT_PUBLIC_PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
